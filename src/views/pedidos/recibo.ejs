<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <style>
    body { font-family: system-ui, Arial, sans-serif; max-width: 420px; margin: 40px auto; padding: 0 20px; color: #222; }
    .header { text-align: center; border-bottom: 2px solid #000; padding-bottom: 12px; margin-bottom: 16px; }
    .item { display: flex; justify-content: space-between; border-bottom: 1px dotted #999; padding: 4px 0; }
    .total { font-weight: bold; font-size: 1.3em; margin-top: 12px; }
    @media print { .no-print { display: none } }
  </style>
</head>
<body>
  <div class="header">
    <strong>PONTO DO PISTÃO SUL</strong><br>
    <small>Comanda / Recibo</small>
  </div>

  <p><strong>Pedido #<%= pedido.id %></strong> — <%= pedido.data_venda.toLocaleDateString('pt-BR') %></p>
  <p><strong>Mesa:</strong> <%= pedido.mesa?.nome || '—' %> &nbsp;&nbsp; <strong>Cliente:</strong> <%= pedido.cliente?.nome %></p>
  <p><strong>Atendido por:</strong> <%= pedido.usuario.nome %></p>

  <hr style="margin: 16px 0; border: none; border-top: 1px solid #ccc;">

  <% pedido.itens.forEach(item => { 
     const sub = (Number(item.preco) * item.quantidade).toFixed(2);
  %>
    <div class="item">
      <span><%= item.quantidade %>× <%= item.produto.nome %> <%= item.observacao ? '('+item.observacao+')' : '' %></span>
      <span>R$ <%= sub %></span>
    </div>
  <% }) %>

  <div class="total">
    TOTAL: R$ <%= total %>
  </div>

  <% if (pedido.forma_pagamento) { %>
    <p style="margin-top:16px"><strong>Pagamento:</strong> <%= pedido.forma_pagamento %></p>
  <% } %>

  <div style="margin-top: 40px; text-align: center; font-size: 11px; color:#666">
    Obrigado pela preferência!<br>
    Volte sempre • Ponto do Pistão Sul
  </div>

  <div class="no-print" style="margin-top:40px; text-align:center">
    <button onclick="window.print()" style="padding:10px 24px; background:#111; color:#fff; border:none; border-radius:8px; cursor:pointer">🖨️ Imprimir</button>
    <a href="/mesas" style="margin-left:12px; color:#444">Fechar</a>
  </div>
</body>
</html>