<%- include('../partials/header', { title: 'Cardápio Completo' }) %>

<h1 class="text-3xl font-bold tracking-tight mb-6">Cardápio Completo</h1>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
  <% produtos.forEach(p => { %>
    <div class="bg-zinc-900 border border-zinc-800 rounded-3xl overflow-hidden">
      <div class="h-40 bg-zinc-800">
        <img src="/images/produtos/<%= p.imagem %>" class="w-full h-full object-cover" onerror="this.src='https://placehold.co/400x200/27251f/eab308?text=<%= encodeURIComponent(p.nome) %>'">
      </div>
      <div class="p-4">
        <div class="flex justify-between">
          <div class="font-semibold"><%= p.nome %></div>
          <div class="font-semibold text-yellow-400">R$ <%= Number(p.valor).toFixed(2) %></div>
        </div>
        <div class="text-xs text-zinc-400"><%= p.tipo_produto %> <%= p.volume ? '• ' + p.volume : '' %></div>
        <% if (p.descricao) { %>
          <div class="text-xs mt-2 text-zinc-300"><%= p.descricao %></div>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>

<%- include('../partials/footer') %>