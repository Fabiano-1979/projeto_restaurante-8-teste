<%- include('../partials/header', { active: 'admin', title: 'Gerenciar Cardápio' }) %>

<div class="flex justify-between mb-6">
  <h1 class="font-semibold text-3xl tracking-tight">Cardápio / Produtos</h1>
  <a href="/admin" class="text-sm text-yellow-400">← Painel</a>
</div>

<div class="grid lg:grid-cols-5 gap-8">
  <div class="lg:col-span-2">
    <div class="bg-zinc-900 border border-zinc-700 rounded-3xl p-6">
      <h3 class="font-medium mb-4">Novo produto</h3>
      <form action="/admin/produtos" method="POST" class="space-y-3 text-sm">
        <input name="nome" placeholder="Nome do produto" required class="w-full bg-zinc-950 border border-zinc-700 px-4 py-2 rounded-2xl">
        <div class="grid grid-cols-2 gap-3">
          <input name="tipo_produto" placeholder="Tipo (Lanche, Bebida...)" required class="bg-zinc-950 border border-zinc-700 px-4 py-2 rounded-2xl">
          <input name="volume" placeholder="Volume / Porção" class="bg-zinc-950 border border-zinc-700 px-4 py-2 rounded-2xl">
        </div>
        <div class="grid grid-cols-2 gap-3">
          <input name="valor" type="number" step="0.01" placeholder="Valor (ex: 18.90)" required class="bg-zinc-950 border border-zinc-700 px-4 py-2 rounded-2xl">
          <input name="imagem" placeholder="arquivo.png (opcional)" value="hamburguer.png" class="bg-zinc-950 border border-zinc-700 px-4 py-2 rounded-2xl">
        </div>
        <textarea name="descricao" placeholder="Descrição curta" rows="2" class="w-full bg-zinc-950 border border-zinc-700 px-4 py-2 rounded-2xl text-sm"></textarea>
        
        <button class="w-full bg-yellow-400 text-zinc-950 py-2.5 font-semibold rounded-2xl mt-1">Cadastrar no Cardápio</button>
      </form>
    </div>
  </div>

  <div class="lg:col-span-3">
    <div class="text-xs uppercase tracking-widest text-zinc-400 px-1 mb-2">Itens atuais</div>
    <div class="space-y-2">
      <% produtos.forEach(p => { %>
        <div class="bg-zinc-900 border border-zinc-800 flex items-center gap-4 px-4 py-3 rounded-3xl text-sm">
          <img src="/images/produtos/<%= p.imagem %>" class="w-9 h-9 object-cover rounded-2xl bg-zinc-800" onerror="this.style.display='none'">
          <div class="flex-1">
            <div class="font-medium"><%= p.nome %></div>
            <div class="text-xs text-zinc-400"><%= p.tipo_produto %> • R$ <%= Number(p.valor).toFixed(2) %></div>
          </div>
          <form action="/admin/produtos/<%= p.id %>/excluir" method="POST" onsubmit="return confirm('Remover produto do cardápio?')">
            <button class="text-xs text-red-400 hover:text-red-500 px-3">remover</button>
          </form>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>