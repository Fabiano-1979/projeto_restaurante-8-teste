<%- include('../partials/header', { active: 'admin', title: 'Gerenciar Mesas' }) %>

<div class="flex justify-between mb-6">
  <h1 class="font-semibold text-3xl tracking-tight">Mesas</h1>
  <a href="/admin" class="text-sm text-yellow-400">← Painel</a>
</div>

<div class="max-w-md">
  <form action="/admin/mesas" method="POST" class="flex gap-3 mb-6">
    <input type="text" name="nome" placeholder="Nome da mesa (ex: Mesa 09)" required
           class="flex-1 bg-zinc-900 border border-zinc-700 rounded-2xl px-4 py-3 text-sm">
    <button class="bg-yellow-400 text-zinc-950 font-semibold px-6 rounded-2xl">Adicionar</button>
  </form>

  <div class="bg-zinc-900 border border-zinc-800 rounded-3xl divide-y divide-zinc-800">
    <% mesas.forEach(m => { %>
      <div class="flex justify-between items-center px-6 py-3 text-sm">
        <span><%= m.nome %> <span class="text-[10px] text-zinc-400">(<%= m.status %>)</span></span>
        <form action="/admin/mesas/<%= m.id %>/excluir" method="POST" onsubmit="return confirm('Excluir mesa?')">
          <button class="text-red-400 text-xs">excluir</button>
        </form>
      </div>
    <% }) %>
  </div>
</div>

<%- include('../partials/footer') %>