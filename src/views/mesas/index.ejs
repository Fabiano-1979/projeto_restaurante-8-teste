<%- include('../partials/header', { active: 'mesas', title: 'Mesas - Restaurante' }) %>

<div class="flex items-end justify-between mb-6">
  <div>
    <h1 class="text-4xl font-bold tracking-tighter">Mesas</h1>
    <p class="text-zinc-400 mt-1">Selecione uma mesa para iniciar ou gerenciar o atendimento</p>
  </div>
  
  <% if (user.role === 'ADMIN') { %>
    <a href="/admin/mesas" class="text-sm px-4 py-2 bg-zinc-900 hover:bg-zinc-800 border border-zinc-700 rounded-2xl flex items-center gap-2">
      ⚙ Gerenciar Mesas
    </a>
  <% } %>
</div>

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
  <% mesas.forEach(mesa => { 
       const isOcupada = mesa.status === 'ocupada' || mesa.pedidoAberto;
       const statusColor = isOcupada ? 'border-amber-400/60 bg-zinc-900' : 'border-emerald-500/60 hover:border-emerald-400 bg-zinc-900';
  %>
    <div class="group relative border-2 <%= statusColor %> rounded-3xl p-5 flex flex-col transition-all duration-200 hover:shadow-xl hover:-translate-y-0.5">
      
      <!-- Header -->
      <div class="flex items-start justify-between">
        <div>
          <div class="text-2xl font-semibold tracking-tight"><%= mesa.nome %></div>
          <div class="text-[10px] uppercase tracking-[1px] mt-0.5 <%= isOcupada ? 'text-amber-400' : 'text-emerald-400' %>">
            <%= isOcupada ? 'OCUPADA' : 'LIVRE' %>
          </div>
        </div>
        
        <div class="text-4xl opacity-10 group-hover:opacity-20 transition">🍽️</div>
      </div>

      <!-- Client / Order Info -->
      <% if (mesa.pedidoAberto) { %>
        <div class="mt-4 bg-black/40 rounded-2xl p-3 text-sm">
          <div class="font-medium text-amber-300"><%= mesa.clienteAtual?.nome || 'Cliente' %></div>
          <% if (mesa.totalAberto > 0) { %>
            <div class="mt-1 flex items-baseline gap-1">
              <span class="text-xs text-zinc-400">Total atual</span>
              <span class="font-semibold text-lg text-white tabular-nums">R$ <%= mesa.totalAberto %></span>
            </div>
          <% } %>
          <div class="text-[10px] text-zinc-500 mt-1"><%= mesa.pedidoAberto.itens.length %> itens</div>
        </div>
      <% } else if (mesa.clienteAtual) { %>
        <div class="mt-4 text-sm text-zinc-400">
          Último cliente: <span class="text-zinc-300"><%= mesa.clienteAtual.nome %></span>
        </div>
      <% } else { %>
        <div class="mt-6 text-xs text-emerald-500/70">Mesa disponível para atendimento</div>
      <% } %>

      <!-- Actions -->
      <div class="mt-auto pt-5">
        <% if (!isOcupada) { %>
          <!-- Iniciar Atendimento -->
          <form action="/mesas/<%= mesa.id %>/iniciar" method="POST" 
                x-data="{ open: false }" @submit="open = false">
            <button type="button" @click="open = true"
                    class="w-full bg-emerald-500 hover:bg-emerald-400 active:bg-emerald-600 transition text-emerald-950 font-semibold py-3 rounded-2xl text-sm">
              INICIAR ATENDIMENTO
            </button>
            
            <!-- Mini modal inline -->
            <div x-show="open" class="fixed inset-0 bg-black/70 flex items-center justify-center z-50" @click.self="open = false">
              <div @click.stop class="bg-zinc-900 w-full max-w-sm mx-4 rounded-3xl p-6 border border-zinc-700">
                <div class="font-semibold text-lg mb-4">Novo atendimento — <%= mesa.nome %></div>
                
                <div class="space-y-3">
                  <div>
                    <label class="text-xs text-zinc-400">Nome do cliente</label>
                    <input type="text" name="nomeCliente" value="Cliente <%= mesa.nome %>" 
                           class="mt-1 w-full bg-zinc-950 border border-zinc-700 focus:border-yellow-500 rounded-2xl px-4 py-2.5 text-sm">
                  </div>
                  <div>
                    <label class="text-xs text-zinc-400">CPF (opcional)</label>
                    <input type="text" name="cpf" placeholder="000.000.000-00"
                           class="mt-1 w-full bg-zinc-950 border border-zinc-700 focus:border-yellow-500 rounded-2xl px-4 py-2.5 text-sm">
                  </div>
                </div>
                
                <div class="flex gap-3 mt-6">
                  <button type="button" @click="open = false" class="flex-1 py-3 rounded-2xl border border-zinc-700 text-sm">Cancelar</button>
                  <button type="submit" class="flex-1 py-3 rounded-2xl bg-emerald-500 text-emerald-950 font-semibold text-sm">Confirmar</button>
                </div>
              </div>
            </div>
          </form>
        <% } else { %>
          <div class="flex gap-2">
            <a href="/pedidos/<%= mesa.pedidoAberto?.id %>/carrinho" 
               class="flex-1 bg-yellow-400 hover:bg-yellow-300 active:bg-yellow-500 text-zinc-950 font-semibold text-center py-3 rounded-2xl text-sm transition">
              VER / ADICIONAR ITENS
            </a>
            
            <form action="/mesas/<%= mesa.id %>/liberar" method="POST" onsubmit="return confirm('Liberar mesa e finalizar pedido?')">
              <button type="submit" 
                      class="px-4 py-3 border border-red-900 hover:bg-red-950 hover:text-red-400 rounded-2xl text-xs transition">
                LIBERAR
              </button>
            </form>
          </div>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>

<div class="mt-10 text-center">
  <div class="inline-flex items-center gap-2 text-xs bg-zinc-900 border border-zinc-800 px-4 py-2 rounded-3xl text-zinc-400">
    <div class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></div>
    Clique em uma mesa livre para iniciar um novo atendimento
  </div>
</div>

<%- include('../partials/footer') %>